<svg xmlns="http://w3.org" viewBox="0 0 360 360" width="100%" height="100%">
  <defs>
    <!-- Kontrastingas tamsus fonas piktogramos gyliui užtikrinti -->
    <radialGradient id="favicon-bg" cx="50%" cy="50%" r="70%">
      <stop offset="0%" stop-color="#1c0702"/>
      <stop offset="100%" stop-color="#050100"/>
    </radialGradient>

    <!-- Matrix Reloaded oranžinės liepsnos gradientas E-Star žiedui -->
    <linearGradient id="reloaded-orange" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#ffb373"/>
      <stop offset="50%" stop-color="#e95420"/>
      <stop offset="100%" stop-color="#991f00"/>
    </linearGradient>

    <!-- Vidinis NeoVim šerdies gradientas -->
    <linearGradient id="neovim-core" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#ffcc00"/>
      <stop offset="100%" stop-color="#e95420"/>
    </linearGradient>
  </defs>

  <!-- Pagrindinis piktogramos rėmelis / fonas -->
  <rect width="360" height="360" rx="72" fill="url(#favicon-bg)"/>

  <!-- CENTRINIS BRANDUOLYS (E-STAR) -->
  <g transform="translate(180, 180)">
    <!-- Pagrindinis storas Ubuntu žiedas -->
    <circle cx="0" cy="0" r="115" fill="none" stroke="url(#reloaded-orange)" stroke-width="24"/>
    
    <!-- Stambūs, ryškūs protonų mazgai (Ubuntu draugų galvos) -->
    <circle cx="0" cy="-115" r="22" fill="#ffffff"/>
    <circle cx="100" cy="58" r="22" fill="#ffffff"/>
    <circle cx="-100" cy="58" r="22" fill="#ffffff"/>
    
    <!-- Gilios išpjovos, neleidžiančios susilieti elementams mažame ekrane -->
    <path d="M 0,-85 L 0,-145" stroke="#050100" stroke-width="16"/>
    <path d="M 74,43 L 126,73" stroke="#050100" stroke-width="16"/>
    <path d="M -74,43 L -126,73" stroke="#050100" stroke-width="16"/>

    <!-- NeoVim integracija pačiame žvaigždės centre -->
    <g transform="scale(0.9) translate(-32, -37)">
      <path d="M0,10 L20,0 L20,65 L0,75 Z" fill="url(#neovim-core)" opacity="0.95"/>
      <path d="M45,0 L65,10 L65,75 L45,65 Z" fill="url(#neovim-core)"/>
      <path d="M20,0 L45,65 L45,65 L20,15 Z" fill="#ffffff"/>
    </g>
  </g>
</svg>
